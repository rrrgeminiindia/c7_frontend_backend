# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored — secrets NEVER get committed, and NEVER ship in a browser.

# --- Groq (the AI model, from L05/L06) -------------------------------------
GROQ_API_KEY=your-groq-api-key

# --- Supabase (the database) -----------------------------------------------
# Find these in your Supabase project:  Settings -> API.

# The project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co

# The SERVICE_ROLE key — the master key. It bypasses every rule.
# It lives ONLY here, on the server we control. If a browser can see it,
# you have leaked your whole database. Not once, not for testing, not for
# five minutes. (The other key, `anon`, is the one that may ship publicly.)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
